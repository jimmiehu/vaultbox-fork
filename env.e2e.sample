# Copy this file to .env.e2e before running npm run test:e2e.
# Use a throwaway Dropbox account or disposable folder.

# Public app key. Defaults to the Vaultbox for Obsidian app key if omitted.
# VAULTBOX_E2E_DROPBOX_APP_KEY=k671hqjipp2sdpl

# Required. Generate this via Vaultbox OAuth and copy it from local plugin data,
# or use a one-off local helper while developing.
VAULTBOX_E2E_DROPBOX_REFRESH_TOKEN=sl.your-refresh-token

# Optional. The test creates and deletes timestamped folders below this path.
# VAULTBOX_E2E_DROPBOX_TEST_ROOT=/Vaultbox E2E

# Set true to keep the disposable Dropbox folder after the run.
# VAULTBOX_E2E_KEEP_ARTIFACTS=false

# Use a custom env file location.
# VAULTBOX_E2E_ENV_FILE=/path/to/env
