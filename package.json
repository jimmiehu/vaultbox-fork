{
  "name": "vaultbox",
  "version": "0.1.0",
  "description": "An Obsidian plugin for syncing a vault directly with a selected Dropbox folder.",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs --watch",
    "build": "tsc --noEmit --skipLibCheck && node esbuild.config.mjs production",
    "test": "vitest run",
    "local-install": "npm run build && node local-install.mjs",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian",
    "obsidian-plugin",
    "dropbox",
    "sync"
  ],
  "author": "grumpydev",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.11.30",
    "esbuild": "^0.28.0",
    "obsidian": "^1.5.12",
    "tslib": "^2.6.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.6"
  }
}
